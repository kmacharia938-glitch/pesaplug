# ================================
# Pesaplug environment configuration
# Copy this file to `.env` and fill in your real values.
# NEVER commit your real .env to git.
# ================================

# --- App ---
PORT=3000
BASE_URL=https://pesaplug.onrender.com

# Secret used to sign login tokens. Use a long random string.
JWT_SECRET=change-this-to-a-long-random-secret

# --- Earning rules (KSh) ---
REWARD_PER_VIDEO=20
STREAK_REWARD=10
VIDEO_LENGTH_SECONDS=30
MIN_WITHDRAW=240

# --- Admin panel login (https://pesaplug.onrender.com/admin) ---
ADMIN_USER=admin
ADMIN_PASS=change-this-admin-password

# ================================
# MONETIZATION (owner earns; users get a cut)
# ================================
# Referrals
REFERRAL_SIGNUP_BONUS=20
REFERRAL_REFERRER_BONUS=50
REFERRAL_ON_FIRST_VIDEO=true

# Offerwall (real provider: cpx | bitlabs). Leave PUBLISHER_ID blank = demo mode.
OFFERWALL_ENABLED=true
OFFERWALL_PROVIDER=cpx
OFFERWALL_PUBLISHER_ID=
OFFERWALL_SECRET_KEY=
OFFERWALL_REWARD=15
OFFERWALL_POSTBACK_SECRET=change-me-postback-secret
OFFERWALL_OWNER_REVENUE=8

# Rewarded ads (real: set ADS_PUBLISHER_ID = your Google AdSense ca-pub-XXXX).
AD_REWARD=5
AD_OWNER_REVENUE=3
ADS_PUBLISHER_ID=

# ================================
# M-PESA (Safaricom Daraja) - B2C payouts
# ================================
# Set to "sandbox" for testing, "production" for live payouts.
MPESA_ENV=sandbox

# From your Daraja app (Consumer Key & Secret)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# Your B2C shortcode (PartyA). In sandbox use the test shortcode from Daraja.
MPESA_SHORTCODE=

# The API operator username configured on the shortcode (often "testapi" in sandbox).
MPESA_INITIATOR_NAME=

# ONE of the two options below is required to authorize B2C:
# Option A) Provide the initiator password + the Safaricom public cert path,
#           and the server will generate the SecurityCredential for you.
MPESA_INITIATOR_PASSWORD=
# Path to Safaricom public certificate (.cer). Sandbox & production certs differ.
# Download from Daraja portal. On Render, either commit this file or use Option B.
MPESA_CERT_PATH=server/certs/SandboxCertificate.cer

# Option B) OR paste a pre-generated SecurityCredential directly (skips encryption).
# Easiest for cloud hosts like Render — no cert file needed. Generate it with:
#   openssl rsautl -encrypt -certin -inkey dummy -in <(echo password) ...  (or use Daraja's tool)
MPESA_SECURITY_CREDENTIAL=

# B2C command: BusinessPayment | SalaryPayment | PromotionPayment
MPESA_COMMAND_ID=BusinessPayment

# BASE_URL MUST be your public URL so Safaricom can call back the result.
# On Render set: BASE_URL=https://pesaplug.onrender.com
# For local testing use a tunnel: ngrok http 3000  ->  BASE_URL=https://xxxx.ngrok-free.app
BASE_URL=https://pesaplug.onrender.com

# Verify setup any time (no secrets printed): node server/check-mpesa.js
